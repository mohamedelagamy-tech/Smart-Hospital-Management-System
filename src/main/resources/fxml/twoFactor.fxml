<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.TwoFactorController">

    <ImageView fx:id="backgroundView" fitHeight="650" fitWidth="900"
               preserveRatio="false"
               AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />

    <Pane style="-fx-background-color: rgba(10,30,70,0.45);"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />

    <VBox alignment="CENTER"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <children>
            <VBox alignment="CENTER" maxWidth="420" spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 40, 0, 0, 10);">
                <children>

                    <ImageView fx:id="logoView" fitHeight="80" fitWidth="80"
                               preserveRatio="true" />

                    <Label text="Two-Factor Authentication"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />

                    <Label fx:id="subtitleLabel"
                           text="We sent a 6-digit code to your email"
                           style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-text-alignment: center;"
                           wrapText="true" maxWidth="320" />

                    <Separator />

                    <VBox spacing="6" maxWidth="320">
                        <Label text="VERIFICATION CODE"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />
                        <TextField fx:id="codeField"
                                   promptText="Enter 6-digit code"
                                   style="-fx-pref-height: 48px; -fx-font-size: 22px; -fx-alignment: CENTER; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-background-color: #F8FAFC; -fx-letter-spacing: 8px;"
                                   maxWidth="320" />
                    </VBox>

                    <Label fx:id="timerLabel"
                           text="Code expires in 10:00"
                           style="-fx-font-size: 11px; -fx-text-fill: #888;" />

                    <Label fx:id="errorLabel" text=""
                           style="-fx-font-size: 11px; -fx-text-fill: #A32D2D;"
                           wrapText="true" maxWidth="320" />

                    <Button fx:id="verifyButton" text="✓  Verify Code"
                            maxWidth="320" prefHeight="44"
                            onAction="#handleVerify"
                            style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" />

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Didn't receive the code?"
                               style="-fx-font-size: 11px; -fx-text-fill: #888;" />
                        <Button fx:id="resendButton" text="Resend"
                                onAction="#handleResend"
                                style="-fx-background-color: transparent; -fx-text-fill: #1F4E79; -fx-font-size: 11px; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;" />
                    </HBox>
                    <Button text="← Back to Login"
                            onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-font-size: 11px; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;" />

                </children>
            </VBox>
        </children>
    </VBox>
</AnchorPane>