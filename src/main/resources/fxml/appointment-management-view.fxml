<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" styleClass="app-background"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shms.controller.AppointmentManagementController">

    <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
          spacing="10" styleClass="top-bar">
        <Button onAction="#handleBack" styleClass="back-button" text="← Back" />
        <Label style="-fx-font-size: 24px;" styleClass="top-bar-title" text="Appointment Management" />
    </HBox>

    <HBox fx:id="summaryBar" spacing="12" style="-fx-padding:16 20 8 20;" />

    <Label fx:id="patientHeaderLabel" managed="false" visible="false"
           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #185FA5; -fx-padding: 8 20 0 20;" />

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 20 8 20;">
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card"
              style="-fx-padding: 0 16;" HBox.hgrow="ALWAYS">
            <Label styleClass="muted-text" text="🔍" />
            <TextField fx:id="searchField" onAction="#handleSearch" prefHeight="42"
                       promptText="Search appointments..."
                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"
                       HBox.hgrow="ALWAYS" />
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 20 12 20;">
        <Button fx:id="bookBtn" onAction="#handleBook" styleClass="primary-button"
                style="-fx-background-radius: 20;" text="+ Book" />
        <Button fx:id="cancelBtn" onAction="#handleCancel" text="✕ Cancel"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-border-width: 0; -fx-cursor: hand;" />
        <Button onAction="#handleRefresh" text="↻ Refresh"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-border-width: 0; -fx-cursor: hand;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#filterAll" text="All"
                style="-fx-background-color: #185FA5; -fx-text-fill: white;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-border-width: 0;" />
        <Button onAction="#filterScheduled" text="Scheduled"
                style="-fx-background-color: #534AB7; -fx-text-fill: white;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-border-width: 0;" />
        <Button onAction="#filterCompleted" text="Completed"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-border-width: 0;" />
        <Button onAction="#filterCancelled" text="Cancelled"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                       -fx-background-radius: 20; -fx-padding: 6 16;
                       -fx-font-size: 12px; -fx-cursor: hand; -fx-border-width: 0;" />
    </HBox>

    <VBox style="-fx-padding:0 20 16 20;" VBox.vgrow="ALWAYS">
        <TableView fx:id="appointmentTable" styleClass="card" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" style="-fx-alignment:CENTER;" text="ID" />
                <TableColumn fx:id="colPatient" style="-fx-alignment:CENTER;" text="Patient" />
                <TableColumn fx:id="colDoctor" style="-fx-alignment:CENTER;" text="Doctor" />
                <TableColumn fx:id="colDate" style="-fx-alignment:CENTER;" text="Date" />
                <TableColumn fx:id="colTime" style="-fx-alignment:CENTER;" text="Time" />
                <TableColumn fx:id="colStatus" style="-fx-alignment:CENTER;" text="Status" />
                <TableColumn fx:id="colNotes" style="-fx-alignment:CENTER;" text="Notes" />
            </columns>
        </TableView>
    </VBox>
</VBox>