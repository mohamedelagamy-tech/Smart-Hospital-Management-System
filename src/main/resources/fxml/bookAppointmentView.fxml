<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shms.controller.BookAppointmentController"
      spacing="0"
      style="-fx-background-color: #f4f6f9;">

      <VBox style="-fx-background-color: #1F4E79;" prefHeight="70">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <Label text="Book Appointment"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Schedule a new appointment"
                   style="-fx-text-fill: #8888aa; -fx-font-size: 12px;"/>
      </VBox>

      <VBox spacing="14">
            <padding><Insets top="24" right="30" bottom="24" left="30"/></padding>

            <HBox fx:id="patientRow" spacing="0">
                  <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Patient"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                        <ComboBox fx:id="patientCombo"
                                  promptText="Select a patient"
                                  prefWidth="340" prefHeight="38"
                                  style="-fx-background-color: white; -fx-border-color: #dde1e7;
                                 -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
                  </VBox>
            </HBox>

            <VBox spacing="5">
                  <Label text="Doctor"
                         style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                  <ComboBox fx:id="doctorCombo"
                            promptText="Select a doctor"
                            prefWidth="340" prefHeight="38"
                            style="-fx-background-color: white; -fx-border-color: #dde1e7;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Date"
                         style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                  <DatePicker fx:id="datePicker"
                              prefWidth="340" prefHeight="38"
                              style="-fx-background-color: white; -fx-border-color: #dde1e7;
                               -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Time"
                         style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                  <ComboBox fx:id="timeCombo"
                            promptText="Select a time slot"
                            prefWidth="340" prefHeight="38"
                            style="-fx-background-color: white; -fx-border-color: #dde1e7;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Notes (optional)"
                         style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                  <TextArea fx:id="notesField"
                            promptText="Any additional notes..."
                            prefWidth="340" prefHeight="70"
                            style="-fx-background-color: white; -fx-border-color: #dde1e7;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <Label fx:id="statusLabel" prefWidth="340" wrapText="true"
                   style="-fx-font-size: 12px;"/>

            <HBox spacing="10">
                  <Button text="Book Appointment"
                          prefWidth="235" prefHeight="42"
                          onAction="#handleBook"
                          style="-fx-background-color: #1F4E79; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                  <Button text="Cancel"
                          prefWidth="95" prefHeight="42"
                          onAction="#handleClose"
                          style="-fx-background-color: white; -fx-text-fill: #1F4E79;
                           -fx-font-size: 13px; -fx-border-color: #dde1e7;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

      </VBox>
</VBox>