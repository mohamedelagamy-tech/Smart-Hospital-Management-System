<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shms.controller.BookAppointmentController"
      spacing="0"
      styleClass="app-background">

      <VBox styleClass="top-bar" prefHeight="70">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <Label text="Book Appointment" styleClass="top-bar-title" style="-fx-font-size: 18px;"/>
            <Label text="Schedule a new appointment"
                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;"/>
      </VBox>

      <VBox spacing="14">
            <padding><Insets top="24" right="30" bottom="24" left="30"/></padding>

            <HBox fx:id="patientRow" spacing="0">
                  <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Patient" styleClass="body-text" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="patientSearchField"
                                   promptText="🔍 Search patient by name or ID"
                                   prefWidth="340" prefHeight="38"
                                   styleClass="text-field"
                                   style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
                        <ListView fx:id="patientResults"
                                  prefWidth="340" styleClass="list-view"
                                  style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
                  </VBox>
            </HBox>

            <VBox spacing="5">
                  <Label text="Doctor" styleClass="body-text" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                  <ComboBox fx:id="doctorCombo"
                            promptText="Select a doctor"
                            prefWidth="340" prefHeight="38"
                            styleClass="text-field"
                            style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Date" styleClass="body-text" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                  <DatePicker fx:id="datePicker"
                              prefWidth="340" prefHeight="38"
                              styleClass="text-field"
                              style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Time" styleClass="body-text" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                  <ComboBox fx:id="timeCombo"
                            promptText="Select a time slot"
                            prefWidth="340" prefHeight="38"
                            styleClass="text-field"
                            style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                  <Label text="Notes (optional)" styleClass="body-text" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                  <TextArea fx:id="notesField"
                            promptText="Any additional notes..."
                            prefWidth="340" prefHeight="70"
                            styleClass="text-field"
                            style="-fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
            </VBox>

            <Label fx:id="statusLabel" prefWidth="340" wrapText="true"
                   style="-fx-font-size: 12px;"/>

            <HBox spacing="10">
                  <Button text="Book Appointment"
                          prefWidth="235" prefHeight="42"
                          onAction="#handleBook"
                          styleClass="primary-button"/>
                  <Button text="Cancel"
                          prefWidth="95" prefHeight="42"
                          onAction="#handleClose"
                          style="-fx-background-color: white; -fx-text-fill: #1F4E79;
                           -fx-font-size: 13px; -fx-border-color: #dde1e7;
                           -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

      </VBox>
</VBox>