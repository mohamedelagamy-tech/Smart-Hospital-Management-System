<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.LoginController">
    <children>
        <ImageView fx:id="backgroundView" fitHeight="650" fitWidth="900" preserveRatio="false"
                   AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />

        <Pane style="-fx-background-color: rgba(10,30,70,0.45);"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />

        <VBox alignment="CENTER"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <VBox alignment="CENTER" maxWidth="400" spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 36; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 40, 0, 0, 10);">
                    <children>
                        <ImageView fx:id="logoView" fitHeight="120" fitWidth="120" preserveRatio="true" />

                        <Label text="SMART HOSPITAL MANAGEMENT SYSTEM" style="-fx-font-size: 9px; -fx-text-fill: #2E75B6; -fx-font-weight: bold;" />
                        <Label text="Every patient matters, every moment counts" style="-fx-font-size: 11px; -fx-text-fill: #888888; -fx-text-alignment: center;" wrapText="true" />

                        <Separator prefWidth="320" />

                        <VBox maxWidth="320" spacing="5">
                            <children>
                                <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />
                                <TextField fx:id="usernameField" promptText="👤 Enter your username"
                                           style="-fx-pref-height: 42px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-background-color: #F8FAFC; -fx-font-size: 13px; -fx-pref-width: 320px;" />
                            </children>
                        </VBox>
                        <VBox maxWidth="320" spacing="5">
                            <children>
                                <Label text="PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />
                                <HBox spacing="0" maxWidth="320">
                                    <children>
                                        <PasswordField fx:id="passwordField" promptText="🔒 Enter your password"
                                                       style="-fx-pref-height: 42px; -fx-background-radius: 8 0 0 8; -fx-border-radius: 8 0 0 8; -fx-border-color: #E0E0E0; -fx-background-color: #F8FAFC; -fx-font-size: 13px; -fx-pref-width: 278px;" />
                                        <TextField fx:id="passwordVisible" managed="false" visible="false" promptText="Enter your password"
                                                   style="-fx-pref-height: 42px; -fx-background-radius: 8 0 0 8; -fx-border-radius: 8 0 0 8; -fx-border-color: #E0E0E0; -fx-background-color: #F8FAFC; -fx-font-size: 13px; -fx-pref-width: 278px;" />
                                        <Button fx:id="showPassword" onAction="#handleShowPassword"
                                                style="-fx-pref-height: 42px; -fx-pref-width: 42px; -fx-background-color: #F0F0F0; -fx-background-radius: 0 8 8 0; -fx-border-radius: 0 8 8 0; -fx-border-color: #E0E0E0; -fx-border-width: 1 1 1 0; -fx-cursor: hand; -fx-font-size: 14px;" text="👁" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Label fx:id="errorLabel" text="" style="-fx-font-size: 11px; -fx-pref-width: 320px; -fx-max-width: 320px;" wrapText="true" />
                        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" text="➔  Sign In"
                                style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-height: 44px; -fx-pref-width: 320px; -fx-background-radius: 8; -fx-cursor: hand;" />
                        <Label text="🔒 Secure  •  🏥 Reliable  •  ⚡ Efficient" style="-fx-font-size: 11px; -fx-text-fill: #AAAAAA;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>