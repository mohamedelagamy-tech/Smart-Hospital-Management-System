<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.LoginController" style="-fx-background-color: #1F4E79;">
    <children>
        <VBox alignment="TOP_CENTER" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <VBox alignment="CENTER" prefHeight="120" style="-fx-background-color: #1F4E79;">
                    <children>
                        <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                            <image>
                                <Image url="/images/logo.jpeg" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS" style="-fx-background-color: #F0F4F8;">
                    <children>
                        <VBox alignment="CENTER" spacing="14" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 32; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);" maxWidth="340" VBox.vgrow="NEVER">
                            <VBox.margin><Insets top="-40" /></VBox.margin>
                            <children>
                                <Label text="SHMS" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />
                                <Label text="Every patient matters, every moment counts" style="-fx-font-size: 11px; -fx-text-fill: #888888; -fx-text-alignment: center;" wrapText="true" />
                                <VBox spacing="5" maxWidth="280">
                                    <children>
                                        <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                                        <TextField fx:id="usernameField" promptText="Enter your username" style="-fx-pref-height: 38px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px; -fx-pref-width: 280px;" />
                                    </children>
                                </VBox>
                                <HBox spacing="0" maxWidth="280">
                                    <children>
                                        <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-pref-height: 38px; -fx-background-radius: 6 0 0 6; -fx-border-radius: 6 0 0 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px; -fx-pref-width: 242px;" />
                                        <TextField fx:id="passwordVisible" promptText="Enter your password" visible="false" managed="false" style="-fx-pref-height: 38px; -fx-background-radius: 6 0 0 6; -fx-border-radius: 6 0 0 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px; -fx-pref-width: 242px;" />
                                        <Button fx:id="showPassword" text="👁" onAction="#handleShowPassword" style="-fx-pref-height: 38px; -fx-pref-width: 38px; -fx-background-color: #F0F0F0; -fx-background-radius: 0 6 6 0; -fx-border-radius: 0 6 6 0; -fx-border-color: #E0E0E0; -fx-border-width: 1 1 1 0; -fx-cursor: hand; -fx-font-size: 14px;" />
                                    </children>
                                </HBox>
                                <Label fx:id="errorLabel" text="" style="-fx-font-size: 11px; -fx-pref-width: 280px; -fx-max-width: 280px;" wrapText="true" />
                                <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" mnemonicParsing="false" style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 13px; -fx-pref-height: 40px; -fx-pref-width: 280px; -fx-background-radius: 6; -fx-cursor: hand;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>