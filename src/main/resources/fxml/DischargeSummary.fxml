<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.DischargeSummaryController"
            prefHeight="700.0" prefWidth="1200.0"
            styleClass="app-background">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" styleClass="top-bar" style="-fx-padding: 0 20;">
            <children>
                <Button onAction="#handleBack" text="← Back" styleClass="back-button"/>
                <Label text="🏥  Discharge Summary" styleClass="top-bar-title"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox style="-fx-padding: 20;" spacing="14">
            <children>
                <VBox styleClass="card" style="-fx-padding: 16 20;" spacing="8">
                    <children>
                        <Label text="Select Patient to Discharge" styleClass="card-title" />
                        <ComboBox fx:id="patientComboBox" promptText="Select Patient"
                                  maxWidth="Infinity" prefHeight="38"
                                  onAction="#onPatientSelected"
                                  style="-fx-font-size: 13px;" />
                    </children>
                </VBox>
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="14" style="-fx-padding: 0 0 20 0;">
                            <children>
                                <VBox styleClass="card" style="-fx-padding: 16 20;" spacing="10">
                                    <children>
                                        <Label text="Patient Information" styleClass="card-title"
                                               style="-fx-padding: 0 0 4 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" />
                                        <HBox spacing="40">
                                            <children>
                                                <VBox spacing="3">
                                                    <Label text="NAME" styleClass="muted-text" />
                                                    <Label fx:id="lblName" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                                <VBox spacing="3">
                                                    <Label text="PATIENT ID" styleClass="muted-text" />
                                                    <Label fx:id="lblPatientId" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                                <VBox spacing="3">
                                                    <Label text="ADMISSION" styleClass="muted-text" />
                                                    <Label fx:id="lblAdmission" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                                <VBox spacing="3">
                                                    <Label text="DISCHARGE DATE" styleClass="muted-text" />
                                                    <Label fx:id="lblDischarge" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox styleClass="card" style="-fx-padding: 16 20;" spacing="10">
                                    <children>
                                        <Label text="Medical Details" styleClass="card-title"
                                               style="-fx-padding: 0 0 4 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" />
                                        <HBox spacing="40">
                                            <children>
                                                <VBox spacing="3">
                                                    <Label text="ROOM" styleClass="muted-text" />
                                                    <Label fx:id="lblRoom" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                                <VBox spacing="3">
                                                    <Label text="DOCTOR" styleClass="muted-text" />
                                                    <Label fx:id="lblDoctor" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                                <VBox spacing="3">
                                                    <Label text="DIAGNOSIS" styleClass="muted-text" />
                                                    <Label fx:id="lblDiagnosis" text="—" styleClass="body-text" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox styleClass="card" style="-fx-padding: 16 20;" spacing="10">
                                    <children>
                                        <Label text="Prescriptions" styleClass="card-title"
                                               style="-fx-padding: 0 0 4 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" />
                                        <TableView fx:id="prescriptionsTable" prefHeight="150"
                                                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colMedicine" text="Medicine" prefWidth="240" />
                                                <TableColumn fx:id="colDosage" text="Dosage" prefWidth="120" />
                                                <TableColumn fx:id="colDuration" text="Duration" prefWidth="120" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                                <VBox styleClass="card" style="-fx-padding: 16 20;" spacing="8">
                                    <children>
                                        <Label text="Bill Summary" styleClass="card-title"
                                               style="-fx-padding: 0 0 4 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" />
                                        <HBox>
                                            <Label text="Room Charges" styleClass="body-text" style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblRoomCharges" text="EGP 0" styleClass="body-text" style="-fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox>
                                            <Label text="Medicine Charges" styleClass="body-text" style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblMedicineCharges" text="EGP 0" styleClass="body-text" style="-fx-font-size: 12px;" />
                                        </HBox>
                                        <HBox>
                                            <Label text="Consultation Charges" styleClass="body-text" style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblConsultationCharges" text="EGP 0" styleClass="body-text" style="-fx-font-size: 12px;" />
                                        </HBox>
                                        <Separator />
                                        <HBox>
                                            <Label text="Total Bill" styleClass="card-title" style="-fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblTotalBill" text="EGP 0" styleClass="card-title" style="-fx-font-size: 14px;" />
                                        </HBox>
                                    </children>
                                </VBox>
                                <Button text="🏥  Discharge Patient &amp; Send Summary" maxWidth="Infinity"
                                        prefHeight="44" onAction="#handlePrint"
                                        styleClass="primary-button"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>