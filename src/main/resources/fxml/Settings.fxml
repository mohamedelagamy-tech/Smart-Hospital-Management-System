<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.SettingsController">

    <fx:define>
        <ToggleGroup fx:id="themeGroup" />
        <ToggleGroup fx:id="fontGroup" />
        <ToggleGroup fx:id="langGroup" />
    </fx:define>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" style="-fx-background-color: #1F4E79; -fx-padding: 0 20;">
            <Button onAction="#handleBack" style="-fx-background-color: transparent; -fx-underline: true;-fx-font-size:13px ; -fx-cursor: hand; -fx-padding:14 20;" text="← Back" textFill="WHITE"/>
            <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="⚙  Settings" />
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F4F6F9; -fx-background: #F4F6F9;">
            <content>
                <VBox spacing="16" style="-fx-background-color: #F4F6F9; -fx-padding: 24;">

                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="🎨  Appearance" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Theme" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Choose how SHMS looks" />
                            </VBox>
                            <ToggleButton fx:id="btnLight" onAction="#handleThemeChange" style="-fx-background-color: #E6F1FB; -fx-text-fill: #1F4E79; -fx-font-size: 12px; -fx-background-radius: 8 0 0 8; -fx-cursor: hand; -fx-padding: 8 16;" text="☀️  Light">
                        <toggleGroup>
                           <ToggleGroup fx:id="themeGroup" />
                        </toggleGroup></ToggleButton>
                            <ToggleButton fx:id="btnDark" onAction="#handleThemeChange" style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 12px; -fx-background-radius: 0; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE; -fx-border-width: 0 1 0 1;" text="🌙  Dark" toggleGroup="$themeGroup" />
                            <ToggleButton fx:id="btnHighContrast" onAction="#handleThemeChange" style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 12px; -fx-background-radius: 0 8 8 0; -fx-cursor: hand; -fx-padding: 8 16;" text="⬛  High Contrast" toggleGroup="$themeGroup" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Font Size" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Adjust text size across the app" />
                            </VBox>
                            <ToggleButton fx:id="btnSmall" onAction="#handleFontChange" style="-fx-font-size: 11px; -fx-background-color: white; -fx-text-fill: #555; -fx-background-radius: 8 0 0 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE;" text="A-">
                        <toggleGroup>
                           <ToggleGroup fx:id="fontGroup" />
                        </toggleGroup></ToggleButton>
                            <ToggleButton fx:id="btnMedium" onAction="#handleFontChange" style="-fx-font-size: 13px; -fx-background-color: #E6F1FB; -fx-text-fill: #1F4E79; -fx-background-radius: 0; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE; -fx-border-width: 0 1 0 1;" text="A" toggleGroup="$fontGroup" />
                            <ToggleButton fx:id="btnLarge" onAction="#handleFontChange" style="-fx-font-size: 15px; -fx-background-color: white; -fx-text-fill: #555; -fx-background-radius: 0 8 8 0; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE;" text="A+" toggleGroup="$fontGroup" />
                        </HBox>
                    </VBox>

                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="🌐  Language" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Display Language" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="The app will reload when language changes" />
                            </VBox>
                            <ToggleButton fx:id="btnEnglish" onAction="#handleLanguageChange" style="-fx-background-color: #E6F1FB; -fx-text-fill: #1F4E79; -fx-font-size: 12px; -fx-background-radius: 8 0 0 8; -fx-cursor: hand; -fx-padding: 8 16;" text=" English">
                        <toggleGroup>
                           <ToggleGroup fx:id="langGroup" />
                        </toggleGroup></ToggleButton>
                            <ToggleButton fx:id="btnArabic" onAction="#handleLanguageChange" style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 12px; -fx-background-radius: 0 8 8 0; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE; -fx-border-width: 1 1 1 0;" text="  العربية" toggleGroup="$langGroup" />
                        </HBox>
                    </VBox>

                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="👤  Account" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Change Password" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Update your account password" />
                            </VBox>
                            <Button onAction="#handleChangePassword" style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16;" text="Change →" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Two-Factor Authentication" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Add extra security to your account" />
                            </VBox>
                            <ToggleButton fx:id="btn2FA" onAction="#handle2FAToggle" style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #EEEEEE; -fx-border-width: 1;" text="Enable" />
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
