<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.SettingsController">

    <fx:define>
        <ToggleGroup fx:id="themeGroup" />
        <ToggleGroup fx:id="fontGroup" />
        <ToggleGroup fx:id="langGroup" />
    </fx:define>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" style="-fx-padding: 0 20;" styleClass="top-bar">
            <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-button" text="← Back"/>
            <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="⚙  Settings" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="settings-scroll">
            <content>
                <VBox spacing="16" styleClass="settings-content">

                    <VBox spacing="16" style="-fx-padding: 20;" styleClass="card">
                        <Label fx:id="appearanceLabel" style="-fx-font-size: 14px;" styleClass="card-title" text="🎨  Appearance" />
                        <Separator />

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="themeLabel" styleClass="settings-row-title" text="Theme" />
                                <Label fx:id="themeDescLabel" styleClass="muted-text" text="Choose how SHMS looks across all screens" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">

                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnLight" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #F4F6F9; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#1F4E79" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="white" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#EEEEEE" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                           <toggleGroup>
                              <ToggleGroup fx:id="themeGroup" />
                           </toggleGroup>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="☀  Light" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnDark" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #1A2535; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#0A1520" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#2A3545" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#1A2535" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="🌙  Dark" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnHighContrast" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #000000; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#FFFF00" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="white" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#333333" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="⬛  High Contrast" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnOcean" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #0A1628; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#006080" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#00D4FF" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#0D1F3C" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="🌊  Ocean" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnForest" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #0A1F0A; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#1A6A1A" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#00CC66" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#0F2A0F" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="🌲  Forest" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnPurple" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #0F0A1F; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#5A1A9A" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#BB88FF" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#1A0F3C" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="💜  Purple" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnRose" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #FFF5F7; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#CC2244" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#FFCCD5" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="white" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="🌸  Rose" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <ToggleButton fx:id="btnSand" onAction="#handleThemeChange" prefHeight="60" prefWidth="100" style="-fx-background-color: #F5F0E8; -fx-border-color: #DDDDDD; -fx-border-width: 2; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" toggleGroup="$themeGroup">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="3">
                                            <HBox alignment="CENTER" spacing="3">
                                                <Rectangle arcHeight="4" arcWidth="4" fill="#8A5A2A" height="12" width="20" />
                                                <VBox spacing="2">
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#D4C4A0" height="4" width="30" />
                                                    <Rectangle arcHeight="2" arcWidth="2" fill="#FFFDF8" height="4" width="30" />
                                                </VBox>
                                            </HBox>
                                        </VBox>
                                    </graphic>
                                </ToggleButton>
                                <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="🏜   Sand" />
                            </VBox>

                        </HBox>

                        <Separator />
                    </VBox>

                    <VBox spacing="14" style="-fx-padding: 20;" styleClass="card">
                        <Label fx:id="languageLabel" style="-fx-font-size: 14px;" styleClass="card-title" text="🌐  Language" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="displayLanguageLabel" styleClass="settings-row-title" text="Display Language" />
                                <Label fx:id="languageDescLabel" styleClass="muted-text" text="The app will reload when language changes" />
                            </VBox>
                            <ToggleButton fx:id="btnEnglish" onAction="#handleLanguageChange" styleClass="toggle-left" text="English">
                        <toggleGroup>
                           <ToggleGroup fx:id="langGroup" />
                        </toggleGroup></ToggleButton>
                            <ToggleButton fx:id="btnArabic" onAction="#handleLanguageChange" styleClass="toggle-right" text="  العربية" toggleGroup="$langGroup" />
                        </HBox>
                    </VBox>

                    <VBox spacing="14" style="-fx-padding: 20;" styleClass="card">
                        <Label fx:id="accountLabel" style="-fx-font-size: 14px;" styleClass="card-title" text="👤  Account" />
                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="changePasswordLabel" styleClass="settings-row-title" text="Change Password" />
                                <Label fx:id="changePasswordDescLabel" styleClass="muted-text" text="Update your account password" />
                            </VBox>
                            <Button fx:id="changePasswordBtn" onAction="#handleChangePassword" styleClass="primary-button" text="Change →" />
                        </HBox>

                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label fx:id="twoFactorLabel" styleClass="settings-row-title" text="Two-Factor Authentication" />
                                <Label fx:id="twoFactorDescLabel" styleClass="muted-text" text="Send a verification code to your email on login" />
                            </VBox>
                            <ToggleButton fx:id="btn2FA" onAction="#handle2FAToggle" styleClass="toggle-2fa" text="Enable" />
                        </HBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
