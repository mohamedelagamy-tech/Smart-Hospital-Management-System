<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.PatientBillsController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" style="-fx-background-color: #1F4E79; -fx-padding: 0 20;">
            <children>
                <Button onAction="#handleBack" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 12;" text="← Back" />
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="📄 My Bills" />
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="userLabel" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);" text="Mohamed" />
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F4F6F9; -fx-background: #F4F6F9;">
            <content>
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 20;">
                    <children>
                        <HBox spacing="14">
                            <children>
                                <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1F4E79; -fx-padding: 0 0 8 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" text="📋  Current Bill" />
                                        <VBox spacing="0" style="-fx-padding: 8 0 0 0;">
                                            <children>
                                                <HBox style="-fx-padding: 7 0; -fx-border-color: #F8F8F8; -fx-border-width: 0 0 1 0;">
                                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Bill ID" HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="billIdLabel" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="—" />
                                                </HBox>
                                                <HBox style="-fx-padding: 7 0; -fx-border-color: #F8F8F8; -fx-border-width: 0 0 1 0;">
                                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Doctor" HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="billDoctorLabel" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="—" />
                                                </HBox>
                                                <HBox style="-fx-padding: 7 0; -fx-border-color: #F8F8F8; -fx-border-width: 0 0 1 0;">
                                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Treatment" HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="billTreatmentLabel" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="—" />
                                                </HBox>
                                                <HBox style="-fx-padding: 7 0; -fx-border-color: #F8F8F8; -fx-border-width: 0 0 1 0;">
                                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Status" HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="billStatusLabel" style="-fx-font-size: 11px; -fx-background-color: #FCEBEB; -fx-text-fill: #A32D2D; -fx-background-radius: 99; -fx-padding: 2 8;" text="—" />
                                                </HBox>
                                                <HBox style="-fx-padding: 10 0 4 0;">
                                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="Total" HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="billTotalLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text=" EGP 0" />
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                <VBox prefHeight="351.0" prefWidth="320.0" spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1F4E79; -fx-padding: 0 0 8 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" text="💳  Pay Now" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Select payment method" />
                                        <ComboBox fx:id="paymentMethodCombo" maxWidth="Infinity" promptText="Choose payment method" style="-fx-pref-height: 36px;" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Amount to pay" />
                                        <Slider fx:id="paymentSlider" max="100" min="0" showTickLabels="false" style="-fx-pref-width: 100%; -fx-accent: #1F4E79;" value="100" />
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #888;" text="0 EGP to" HBox.hgrow="ALWAYS" />
                                                <Label fx:id="sliderMaxLabel" style="-fx-font-size: 10px; -fx-text-fill: #888;" text=" 525 EGP (Full)" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 10 14;">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #0C447C;" text="Amount due" HBox.hgrow="ALWAYS" />
                                                <Label fx:id="amountDueLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text=" 525 EGP" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="payButton" maxWidth="Infinity" onAction="#handlePayment" style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-pref-height: 42px; -fx-background-radius: 8; -fx-cursor: hand;" text="Pay 525 EGP" />
                                        <Label fx:id="paymentMessage" style="-fx-font-size: 11px; -fx-text-fill: #1D6A2E;" text="" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;">
                            <children>
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1F4E79; -fx-padding: 0 0 8 0; -fx-border-color: #F0F0F0; -fx-border-width: 0 0 1 0;" text="🕐  Payment History" />
                                <ListView fx:id="historyList" prefHeight="200" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
