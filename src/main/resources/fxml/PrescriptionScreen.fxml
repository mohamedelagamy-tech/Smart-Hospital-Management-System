<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1200" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.PrescriptionController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
              spacing="10" style="-fx-background-color:#1E3A5F;">
            <Button onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-underline: true;
                -fx-font-size:13px ; -fx-cursor: hand; -fx-padding:14 20;"
                    text="← Back" textFill="WHITE"/>
            <Label style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:white;" text="Prescriptions " />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f4f6f9;">
            <VBox fx:id="addFormPane" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12;                          -fx-border-color: #eeeeee; -fx-border-radius: 12;                          -fx-border-width: 1; -fx-padding: 20;">
                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="Add New Prescription" />
                <HBox spacing="12">
                    <TextField fx:id="patientIdField" prefHeight="38" promptText="Patient ID" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;                                       -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="medicineNameField" prefHeight="38" promptText="Medicine Name" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;                                       -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox spacing="12">
                    <TextField fx:id="dosageField" prefHeight="38" promptText="Dosage" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;                                       -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="durationField" prefHeight="38" promptText="Duration" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;                                       -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                </HBox>
                <TextArea fx:id="instructionsField" prefHeight="70" promptText="Instructions" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;                                  -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;" />
                <Button onAction="#handleAddPrescription" prefHeight="38" style="-fx-background-color: #1F4E79; -fx-text-fill: white;                                -fx-font-size: 12px; -fx-font-weight: bold;                                -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20;" text="➕  Add Prescription" />
            </VBox>
            <VBox fx:id="patientViewPane" managed="false" spacing="6" style="-fx-background-color: white; -fx-background-radius: 12;                          -fx-border-color: #eeeeee; -fx-border-radius: 12;                          -fx-border-width: 1; -fx-padding: 20;" visible="false">
                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="Your Prescriptions" />
                <Label fx:id="patientNameLabel" style="-fx-font-size: 11px; -fx-text-fill: #888;" />
            </VBox>
            <VBox style="-fx-background-color: white; -fx-background-radius: 12;                          -fx-border-color: #eeeeee; -fx-border-radius: 12; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
                <TableView fx:id="prescriptionTable" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="90" text="ID" />
                        <TableColumn fx:id="colPatient" prefWidth="160" text="Patient" />
                        <TableColumn fx:id="colDoctor" prefWidth="150" text="Doctor" />
                        <TableColumn fx:id="colMedicine" prefWidth="140" text="Medicine" />
                        <TableColumn fx:id="colDosage" prefWidth="90" text="Dosage" />
                        <TableColumn fx:id="colDuration" prefWidth="90" text="Duration" />
                        <TableColumn fx:id="colInstructions" prefWidth="260" text="Instructions" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>