<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.PrescriptionController"
            prefHeight="700.0" prefWidth="1200.0">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10"
              style="-fx-background-color: #1F4E79; -fx-padding: 0 20;">
            <children>
                <Button onAction="#handleBack" text="← Back"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 12;" />
                <Label text="💊  Prescriptions"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="roleIndicator" text="Doctor View"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7); -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 99; -fx-padding: 3 10;" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: #F4F6F9; -fx-padding: 20;" spacing="14">
            <children>
                <VBox fx:id="addFormPane" spacing="14"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;">
                    <children>
                        <Label text="Add New Prescription"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F4E79; -fx-padding: 0 0 4 0;" />
                        <HBox spacing="12">
                            <children>
                                <TextField fx:id="patientIdField" promptText="Patient ID"
                                           style="-fx-pref-height: 38px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px;"
                                           HBox.hgrow="ALWAYS" />
                                <TextField fx:id="medicineNameField" promptText="Medicine Name"
                                           style="-fx-pref-height: 38px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px;"
                                           HBox.hgrow="ALWAYS" />
                                <TextField fx:id="dosageField" promptText="Dosage"
                                           style="-fx-pref-height: 38px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px;"
                                           HBox.hgrow="ALWAYS" />
                                <TextField fx:id="durationField" promptText="Duration"
                                           style="-fx-pref-height: 38px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px;"
                                           HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <TextArea fx:id="instructionsField" promptText="Instructions"
                                          prefHeight="70" HBox.hgrow="ALWAYS"
                                          style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 12px; -fx-padding: 8 12;" />
                                <Button text="➕  Add Prescription" onAction="#handleAddPrescription"
                                        style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-pref-height: 70px; -fx-pref-width: 160px; -fx-background-radius: 8; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox fx:id="patientViewPane" spacing="10" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;">
                    <children>
                        <Label text="Your Prescriptions"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" />
                        <Label fx:id="patientNameLabel" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #888;" />
                    </children>
                </VBox>
                <VBox VBox.vgrow="ALWAYS" spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 0;">
                    <children>
                        <TableView fx:id="prescriptionTable" VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colId" text="ID" prefWidth="80" />
                                <TableColumn fx:id="colPatient" text="Patient ID" prefWidth="100" />
                                <TableColumn fx:id="colDoctor" text="Doctor ID" prefWidth="100" />
                                <TableColumn fx:id="colMedicine" text="Medicine" prefWidth="160" />
                                <TableColumn fx:id="colDosage" text="Dosage" prefWidth="100" />
                                <TableColumn fx:id="colDuration" text="Duration" prefWidth="100" />
                                <TableColumn fx:id="colInstructions" text="Instructions" prefWidth="300" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>