<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.DoctorController" styleClass="app-background">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backBtn" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="← Back"/>
            <Label fx:id="pageTitle" style="-fx-font-size: 24px;" text=" Doctor Management" styleClass="top-bar-title">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>
   </top>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-radius: 12;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox prefHeight="100.0" prefWidth="40.0" spacing="10.0">
               <children>
                  <VBox prefHeight="100.0" prefWidth="196.0">
                     <children>
                        <Pane prefHeight="34.0" prefWidth="196.0">
                           <children>
                              <TextField fx:id="searchField" layoutX="-2.0" layoutY="1.0" prefHeight="25.0" prefWidth="191.0" promptText="🔍Search by name or ID. . ." styleClass="text-field"/>
                           </children>
                        </Pane>
                        <Button fx:id="addBtn" mnemonicParsing="false" onAction="#handleAddDoctor" prefHeight="26.0" prefWidth="120.0" styleClass="primary-button" text="+ Add Doctor">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
                  <ComboBox fx:id="departmentFilter" prefHeight="0.0" prefWidth="163.0" promptText="Filter by Department" />
                  <Button fx:id="allBtn" mnemonicParsing="false" onAction="#handleAll" text="All" />
                  <Button fx:id="availableBtn" mnemonicParsing="false" onAction="#handleAvailable" prefWidth="80.0" style="-fx-background-color: #16A34A;" text="Available" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="busyBtn" mnemonicParsing="false" onAction="#handleBusy" prefWidth="60.0" style="-fx-background-color: #D97706;" text="Busy" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="inSurgeryBtn" mnemonicParsing="false" onAction="#handleInSurgery" prefWidth="80.0" style="-fx-background-color: #DC2626;" text="In Surgery" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
                  <ComboBox fx:id="sortCombo" prefWidth="150.0" />
                  <Button fx:id="resetBtn" mnemonicParsing="false" text="reset" />
               </children>
            </HBox>
            <TableView fx:id="doctorTable" prefHeight="360.0" prefWidth="879.0">
               <columns>
                  <TableColumn fx:id="idCol" prefWidth="37.399994254112244" text="ID" />
                  <TableColumn fx:id="nameCol" prefWidth="139.60000610351562" text="Name" />
                  <TableColumn fx:id="departmentCol" prefWidth="145.80001831054688" text="Department" />
                  <TableColumn fx:id="salaryCol" prefWidth="91.20001220703125" text="Salary" />
                  <TableColumn fx:id="workingDaysCol" prefWidth="88.00003051757812" text="Working Days" />
                  <TableColumn fx:id="workingHoursCol" prefWidth="91.99996948242188" text="Working Hours" />
                  <TableColumn fx:id="ratingCol" prefWidth="46.0" text="Rating" />
                  <TableColumn fx:id="statusCol" prefWidth="73.0" text="Status" />
                  <TableColumn fx:id="actionsCol" prefWidth="230.20001220703125" text="Actions" />
               </columns>
            </TableView>
            <HBox prefHeight="40.0" prefWidth="200.0">
               <children>
                  <Label fx:id="statusLabel" prefHeight="22.0" prefWidth="138.0" text="Total Doctors : 0" styleClass="muted-text"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>