<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1200" styleClass="app-background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.MedicalRecordsController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
              spacing="10" styleClass="top-bar">
            <Button fx:id="backBtn" onAction="#handleBack" styleClass="back-button" text="← Back"/>
            <Label fx:id="titleLabel" styleClass="top-bar-title" style="-fx-font-size:24;" text="Medical Records" />
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card" style="-fx-padding: 0 16;">
                <Label styleClass="muted-text" text="🔍" />
                <TextField fx:id="searchField" onKeyReleased="#onSearch" prefHeight="42" promptText="Search by patient, doctor, or diagnosis..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
            </HBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
                <TableView fx:id="recordsTable" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNumber" prefWidth="50" text="#" />
                        <TableColumn fx:id="colPatient" prefWidth="160" text="Patient" />
                        <TableColumn fx:id="colDoctor" prefWidth="150" text="Doctor" />
                        <TableColumn fx:id="colDate" prefWidth="100" text="Date" />
                        <TableColumn fx:id="colDiagnosis" prefWidth="160" text="Diagnosis" />
                        <TableColumn fx:id="colTreatment" prefWidth="180" text="Treatment" />
                        <TableColumn fx:id="colStatus" prefWidth="110" text="Status" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>