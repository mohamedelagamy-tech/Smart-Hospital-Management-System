<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" style="-fx-padding: 0 20;" styleClass="top-bar">
            <ImageView fx:id="logoView" fitHeight="120" fitWidth="120" preserveRatio="true" />
            <Label style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 14px;" text="|" />
            <Label style="-fx-font-size: 22px; -fx-text-fill: rgba(255,255,255,0.6);" text="Smart Hospital Management System" />
            <HBox HBox.hgrow="ALWAYS" />
            <Label fx:id="clockLabel" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);" />
            <Label style="-fx-text-fill: rgba(255,255,255,0.2);" text="|" />
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 20; -fx-padding: 4 12 4 4;">
                <StackPane maxHeight="26" maxWidth="26" prefHeight="26" prefWidth="26" styleClass="user-avatar">
                    <Label fx:id="userInitials" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: white;" text="MO" />
                </StackPane>
                <VBox spacing="1">
                    <Label fx:id="userLabel" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: white;" text="Mohamed" />
                    <Label fx:id="roleLabel" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5);" text="ADMIN" />
                </VBox>
            </HBox>
            <Button onAction="#showSettings" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 10;" text="⚙" />
            <Button onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 12;" text="→] Logout" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200" spacing="2" style="-fx-padding: 14 8;" styleClass="sidebar">
            <Label fx:id="labelMain" styleClass="section-label" text="MAIN" />
            <Button fx:id="btnDashboard" maxWidth="Infinity" onAction="#showDashboard" styleClass="nav-button-active" text="🏠  Dashboard" />
            <Button fx:id="btnPatients" maxWidth="Infinity" onAction="#showPatients" styleClass="nav-button" text="👥  Patients" />
            <Button fx:id="btnDoctors" maxWidth="Infinity" onAction="#showDoctors" styleClass="nav-button" text="👨‍⚕️  Doctors" />
            <Button fx:id="btnAppointments" maxWidth="Infinity" onAction="#showAppointments" styleClass="nav-button" text="📅  Appointments" />
            <Button fx:id="btnCalendar" maxWidth="Infinity" onAction="#showCalendar" styleClass="nav-button" text="🗓️  Calendar" />
            <Label fx:id="labelMedical" styleClass="section-label" text="MEDICAL" />
            <Button fx:id="btnRecords" maxWidth="Infinity" onAction="#showRecords" styleClass="nav-button" text="📋  Medical Records" />
            <Button fx:id="btnPrescriptions" maxWidth="Infinity" onAction="#showPrescriptions" styleClass="nav-button" text="💊  Prescriptions" />
            <Button fx:id="btnEmergency" maxWidth="Infinity" onAction="#showEmergency" styleClass="nav-button" text="🚨  Emergency Queue" />
            <Button fx:id="btnPharmacy" maxWidth="Infinity" onAction="#showPharmacy" styleClass="nav-button" text="🧪  Pharmacy" />
            <Label fx:id="labelAdmin" styleClass="section-label" text="ADMIN" />
            <Button fx:id="btnBilling" maxWidth="Infinity" onAction="#showBilling" styleClass="nav-button" text="💰  Billing" />
            <Button fx:id="btnRooms" maxWidth="Infinity" onAction="#showRooms" styleClass="nav-button" text="🛏  Rooms" />
            <Button fx:id="btnDepartments" maxWidth="Infinity" onAction="#showDepartments" styleClass="nav-button" text="🏥  Departments" />
            <Button fx:id="btnAuditLog" maxWidth="Infinity" onAction="#showAuditLog" styleClass="nav-button" text="📝  Audit Log" />
            <Button fx:id="btnStatistics" maxWidth="Infinity" onAction="#showStatistics" styleClass="nav-button" text="📊  Statistics" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;" styleClass="app-background">
            <VBox spacing="3">
                <Label fx:id="welcomeLabel" styleClass="welcome-label" text="Good morning 👋" />
                <Label styleClass="muted-text" text="Here's what's happening at SHMS today" />
            </VBox>
            <HBox spacing="12">
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-blue">
                        <Label style="-fx-font-size: 18px;" text="👥" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statPatients" styleClass="stat-number" text="0" />
                        <Label styleClass="muted-text" text="Total Patients" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-green">
                        <Label style="-fx-font-size: 18px;" text="👨‍⚕️" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statDoctors" styleClass="stat-number" text="0" />
                        <Label styleClass="muted-text" text="Doctors on Duty" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-orange">
                        <Label style="-fx-font-size: 18px;" text="📅" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statAppointments" styleClass="stat-number" text="0" />
                        <Label styleClass="muted-text" text="Scheduled Appointments" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-purple">
                        <Label style="-fx-font-size: 18px;" text="🛏" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statRooms" styleClass="stat-number" text="0/0" />
                        <Label styleClass="muted-text" text="Rooms Available" />
                    </VBox>
                </HBox>
            </HBox>
            <HBox spacing="12">
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-green">
                        <Label style="-fx-font-size: 18px;" text="💰" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statRevenue" styleClass="stat-number" text="EGP 0" />
                        <Label styleClass="muted-text" text="Total Revenue Collected" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-orange">
                        <Label style="-fx-font-size: 18px;" text="⏳" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statOutstanding" styleClass="stat-number" text="EGP 0" />
                        <Label styleClass="muted-text" text="Outstanding Payments" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-red">
                        <Label style="-fx-font-size: 18px;" text="🚨" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statEmergency" styleClass="stat-number-red" text="0" />
                        <Label styleClass="muted-text" text="Emergency Patients" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" prefHeight="86" spacing="14" style="-fx-padding: 16;" styleClass="card" HBox.hgrow="ALWAYS">
                    <StackPane maxHeight="42" maxWidth="42" prefHeight="42" prefWidth="42" styleClass="stat-icon-blue">
                        <Label style="-fx-font-size: 18px;" text="💊" />
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="statPrescriptions" styleClass="stat-number" text="0" />
                        <Label styleClass="muted-text" text="Active Prescriptions" />
                    </VBox>
                </HBox>
            </HBox>

            <Pane VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnMap" onAction="#showMap" styleClass="primary-button" text="🗺  Hospital Map" />
            </HBox>
        </VBox>
    </center>
</BorderPane>