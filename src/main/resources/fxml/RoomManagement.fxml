<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.RoomManagementController"
            prefHeight="700" prefWidth="1200"
            style="-fx-background-color: #f4f6f9;">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="12"
              style="-fx-background-color: #1F4E79; -fx-padding: 0 24;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;
                           -fx-underline: true;"/>
            <Label text="🛏  Room Management"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f4f6f9;">

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #dde1e7;
                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 16;">
                <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #aaa;"/>
                <TextField fx:id="searchField"
                           promptText="Search rooms or patients..."
                           prefHeight="42" HBox.hgrow="ALWAYS"
                           onKeyReleased="#onSearch"
                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"/>
            </HBox>
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <FlowPane fx:id="cardsPane"
                          hgap="16" vgap="16"
                          style="-fx-background-color: transparent;">
                    <padding><Insets top="4" right="4" bottom="8" left="4"/></padding>
                </FlowPane>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>