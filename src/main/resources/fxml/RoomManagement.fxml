<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shms.controller.RoomManagementController"
      style="-fx-background-color: #dde8f5;"
      spacing="24">

    <padding><Insets top="36" right="44" bottom="36" left="44"/></padding>
    <Button text="← Back" onAction="#handleBack"
            style="-fx-background-color: transparent; -fx-text-fill: #1a6fba;
               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;"/>
    <Label text="Room Management"
           style="-fx-font-family: Georgia; -fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1a1d23;"/>

    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: white; -fx-border-color: #b0c4de; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 16 10 16;">
        <Label text="🔍" style="-fx-font-size: 16px;"/>
        <TextField fx:id="searchField"
                   promptText="Search rooms or patients..."
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14px;"
                   HBox.hgrow="ALWAYS"
                   onKeyReleased="#onSearch"/>
    </HBox>

    <ScrollPane fx:id="scrollPane"
                fitToWidth="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">

        <FlowPane fx:id="cardsPane"
                  style="-fx-background-color: transparent;"
                  hgap="18" vgap="18">
            <padding><Insets top="4" right="4" bottom="8" left="4"/></padding>
        </FlowPane>

    </ScrollPane>

</VBox>
