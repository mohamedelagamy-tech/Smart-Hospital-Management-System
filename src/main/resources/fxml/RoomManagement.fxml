<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700"
            prefWidth="1200"
            style="-fx-background-color: #f4f6f9;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.RoomManagementController">
    <top>
        <HBox>
        HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
        spacing="10" style="-fx-background-color:#1E3A5F;">
        <Button onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-underline: true;
                -fx-font-size:13px ; -fx-cursor: hand; -fx-padding:14 20;"
                text="← Back" textFill="WHITE"/>
        <Label style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:white;" text="🛏 Room Management " />
    </HBox>
    </top>
    <center>
        <VBox spacing="16"
              style="-fx-padding: 24; -fx-background-color: #f4f6f9;">
            <HBox alignment="CENTER_LEFT"
                  spacing="10"
                  style="-fx-background-color: white;
                          -fx-border-color: #dde1e7;
                          -fx-border-radius: 8;
                          -fx-background-radius: 8;
                          -fx-padding: 0 16;">

                <Label style="-fx-font-size: 14px; -fx-text-fill: #aaa;"
                       text="🔍" />
                <TextField fx:id="searchField"
                           onKeyReleased="#onSearch"
                           prefHeight="42"
                           promptText="Search rooms, type or department..."
                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent;
                                  -fx-font-size: 13px;"
                           HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ToggleButton fx:id="btnAll"
                              text="All"
                              style="-fx-background-color: #1F4E79;
                                     -fx-text-fill: white;
                                     -fx-border-radius: 20;
                                     -fx-background-radius: 20;
                                     -fx-font-size: 13px;
                                     -fx-cursor: hand;
                                     -fx-pref-height: 34px;" />
                <ToggleButton fx:id="btnAvailable"
                              text="Available"
                              style="-fx-background-color: #27ae60;
                                     -fx-text-fill: white;
                                     -fx-border-radius: 20;
                                     -fx-background-radius: 20;
                                     -fx-font-size: 13px;
                                     -fx-cursor: hand;
                                     -fx-pref-height: 34px;" />
                <ToggleButton fx:id="btnOccupied"
                              text="Occupied"
                              style="-fx-background-color: #e74c3c;
                                     -fx-text-fill: white;
                                     -fx-border-radius: 20;
                                     -fx-background-radius: 20;
                                     -fx-font-size: 13px;
                                     -fx-cursor: hand;
                                     -fx-pref-height: 34px;" />
                <ToggleButton fx:id="btnCleaning"
                              text="Cleaning"
                              style="-fx-background-color: #f97316;
                                     -fx-text-fill: white;
                                     -fx-border-radius: 20;
                                     -fx-background-radius: 20;
                                     -fx-font-size: 13px;
                                     -fx-cursor: hand;
                                     -fx-pref-height: 34px;" />
            </HBox>
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <FlowPane fx:id="cardsPane"
                              hgap="20"
                              vgap="20"
                              alignment="TOP_CENTER"
                              prefWrapLength="1400"
                              style="-fx-background-color: transparent;">

                        <padding>
                            <Insets top="4" right="4" bottom="8" left="4"/>
                        </padding>

                    </FlowPane>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>