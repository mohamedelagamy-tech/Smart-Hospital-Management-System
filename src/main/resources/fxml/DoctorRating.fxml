<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="651.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.DoctorRatingController">

   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
            spacing="10" style="-fx-background-color: #1E3A5F;">
         <Button mnemonicParsing="false" onAction="#handleBack"
                 style="-fx-background-color: transparent; -fx-underline: true;
                           -fx-font-size:13px; -fx-cursor: hand; -fx-padding:14 20;"
                 text="← Back" textFill="WHITE"/>
         <Label text="Doctor Rating" textFill="WHITE">
            <font><Font name="System Bold" size="24.0"/></font>
         </Label>
      </HBox>
   </top>
   <center>
      <VBox spacing="16" style="-fx-background-color: #F4F7FA;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="24.0" left="30.0" right="30.0" top="24.0"/>
         </padding>
         <VBox spacing="8"
               style="-fx-background-color: WHITE; -fx-background-radius: 12;
                         -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-border-width: 1;">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <Label text="Rate Your Doctor" textFill="#1e3a5f">
               <font><Font name="System Bold" size="18.0"/></font>
            </Label>
            <Label text="Your feedback helps us improve patient care" textFill="#64748b">
               <font><Font size="13.0"/></font>
            </Label>
            <HBox spacing="16" alignment="CENTER_LEFT">
               <Label fx:id="avatarLabel"
                      prefHeight="48" prefWidth="48" alignment="CENTER"
                      style="-fx-background-color: #DBEAFE; -fx-background-radius: 28;"
                      text="DR" textFill="#1d4ed8">
                  <font><Font name="System Bold" size="16.0"/></font>
               </Label>
               <VBox spacing="4">
                  <Label fx:id="doctorNameLabel" text="Dr. Mariam" textFill="#1e3a5f">
                     <font><Font name="System Bold" size="16.0"/></font>
                  </Label>
                  <Label fx:id="doctorSpecLabel" text="Cardiology" textFill="#64748b">
                     <font><Font size="13.0"/></font>
                  </Label>
                  <Label fx:id="dischargeLabel"
                         style="-fx-background-color: #DCFCE7; -fx-background-radius: 999;
                                      -fx-padding: 2 10 2 10;"
                         text="✓ Discharged today" textFill="#166534">
                     <font><Font size="12.0"/></font>
                  </Label>
               </VBox>
            </HBox>
         </VBox>
         <VBox spacing="10"
               style="-fx-background-color: WHITE; -fx-background-radius: 12;
                         -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-border-width: 1;">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <Label text="How would you rate your experience?" textFill="#475569">
               <font><Font size="13.0"/></font>
            </Label>
            <HBox spacing="4" alignment="CENTER_LEFT">
               <Button fx:id="star1Btn" mnemonicParsing="false" onAction="#handleStar1"
                       style="-fx-background-color: transparent; -fx-font-size: 38px;
                                   -fx-cursor: hand; -fx-text-fill: #D1D5DB; -fx-padding: 0 4;" text="★"/>
               <Button fx:id="star2Btn" mnemonicParsing="false" onAction="#handleStar2"
                       style="-fx-background-color: transparent; -fx-font-size: 38px;
                                   -fx-cursor: hand; -fx-text-fill: #D1D5DB; -fx-padding: 0 4;" text="★"/>
               <Button fx:id="star3Btn" mnemonicParsing="false" onAction="#handleStar3"
                       style="-fx-background-color: transparent; -fx-font-size: 38px;
                                   -fx-cursor: hand; -fx-text-fill: #D1D5DB; -fx-padding: 0 4;" text="★"/>
               <Button fx:id="star4Btn" mnemonicParsing="false" onAction="#handleStar4"
                       style="-fx-background-color: transparent; -fx-font-size: 38px;
                                   -fx-cursor: hand; -fx-text-fill: #D1D5DB; -fx-padding: 0 4;" text="★"/>
               <Button fx:id="star5Btn" mnemonicParsing="false" onAction="#handleStar5"
                       style="-fx-background-color: transparent; -fx-font-size: 38px;
                                   -fx-cursor: hand; -fx-text-fill: #D1D5DB; -fx-padding: 0 4;" text="★"/>
            </HBox>
            <Label fx:id="ratingLabel" textFill="#16a34a">
               <font><Font name="System Bold" size="14.0"/></font>
            </Label>
         </VBox>
         <VBox spacing="10" VBox.vgrow="ALWAYS"
               style="-fx-background-color: WHITE; -fx-background-radius: 12;
                         -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-border-width: 1;">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <Label text="Leave a comment (optional)" textFill="#475569">
               <font><Font size="13.0"/></font>
            </Label>
            <TextArea fx:id="commentArea" prefHeight="100" prefWidth="200"
                      promptText="Share details about your visit…" wrapText="true"
                      VBox.vgrow="ALWAYS"/>
         </VBox>
         <Button fx:id="submitBtn" disable="true" mnemonicParsing="false"
                 onAction="#handleSubmit" prefHeight="42" prefWidth="300"
                 style="-fx-background-color: #3B82F6; -fx-background-radius: 8; -fx-cursor: hand;"
                 text="Submit Rating" textFill="WHITE">
            <font><Font name="System Bold" size="14.0"/></font>
         </Button>

         <Label fx:id="successLabel" textFill="#16a34a" visible="false">
            <font><Font name="System Bold" size="14.0"/></font>
         </Label>
      </VBox>
   </center>
</BorderPane>