<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shms.controller.PatientDashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10" style="-fx-background-color: #1F4E79; -fx-padding: 0 20;">
            <children>
                <javafx.scene.image.ImageView fx:id="logoView" fitHeight="59.0" fitWidth="61.0" preserveRatio="true" />
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="SHMS" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 14px;" text="|" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-family: 'Georgia'; -fx-font-style: italic;" text="Patient Portal" />
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="clockLabel" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);" text="10:42 AM" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.2);" text="|" />
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 20; -fx-padding: 4 12 4 4;">
                    <children>
                        <StackPane maxHeight="26" maxWidth="26" prefHeight="26" prefWidth="26" style="-fx-background-color: #2E75B6; -fx-background-radius: 13;">
                            <children>
                                <Label fx:id="userInitials" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: white;" text="MO" />
                            </children>
                        </StackPane>
                        <VBox spacing="1">
                            <children>
                                <Label fx:id="userLabel" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: white;" text="Mohamed" />
                                <Label fx:id="roleLabel" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5);" text="PATIENT" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <Button onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 12;" text="Logout" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200" spacing="2" style="-fx-background-color: #F8FAFC; -fx-border-color: #EEEEEE; -fx-border-width: 0 1 0 0; -fx-padding: 14 8;">
            <children>
                <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #AAAAAA; -fx-padding: 8 8 4 8;" text="MY PORTAL" />
                <Button fx:id="btnHome" maxWidth="Infinity" onAction="#showHome" style="-fx-background-color: #1F4E79; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="🏠  Home" />
                <Button fx:id="btnAppointments" maxWidth="Infinity" onAction="#showAppointments" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;" text="📅  My Appointments" />
                <Button fx:id="btnPrescriptions" maxWidth="Infinity" onAction="#showPrescriptions" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;" text="💊  My Prescriptions" />
                <Button fx:id="btnBills" maxWidth="Infinity" onAction="#showBills" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 9 12; -fx-background-radius: 8; -fx-cursor: hand;" text="💰  My Bills" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F4F6F9; -fx-background: #F4F6F9;">
            <content>
                <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 20;">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #1F4E79; -fx-background-radius: 12; -fx-padding: 20 24;">
                            <children>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="welcomeLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="Welcome back, Mohamed 👋" />
                                        <Label style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);" text="Here's your personal health summary" />
                                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 8; -fx-padding: 8 14; -fx-margin: 4 0 0 0;">
                                            <children>
                                                <Label style="-fx-font-size: 18px;" text="📅" />
                                                <VBox spacing="1">
                                                    <children>
                                                        <Label fx:id="nextApptLabel" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" text="Loading next appointment..." />
                                                        <Label fx:id="nextApptDetail" style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);" text="" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <Button onAction="#showBookAppointments" style="-fx-background-color: white; -fx-text-fill: #1F4E79; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="📅  Book Appointment" />
                            </children>
                        </HBox>

                        <HBox spacing="14">
                            <children>

                                <VBox alignment="CENTER" prefWidth="260" spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                                    <children>
                                        <StackPane maxHeight="64" maxWidth="64" prefHeight="64" prefWidth="64" style="-fx-background-color: #1F4E79; -fx-background-radius: 32;">
                                            <children>
                                                <Label fx:id="profileInitials" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="MO" />
                                            </children>
                                        </StackPane>
                                        <Label fx:id="profileName" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="Mohamed Mazen" />
                                        <Label fx:id="profileStatus" style="-fx-font-size: 11px; -fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32; -fx-background-radius: 99; -fx-padding: 3 10;" text="✓ Active Patient" />
                                        <Separator />
                                        <GridPane hgap="10" maxWidth="220" vgap="8">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Blood Type" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <Label fx:id="profileBlood" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="A-" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Department" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                <Label fx:id="profileDept" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Oncology" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Phone" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                <Label fx:id="profilePhone" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="01558887707" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Address" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                <Label fx:id="profileAddress" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Alexandria" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                            </children>
                                 <columnConstraints>
                                    <ColumnConstraints />
                                    <ColumnConstraints />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                 </rowConstraints>
                                        </GridPane>
                                        <Separator />
                                        <Button maxWidth="Infinity" style="-fx-background-color: #FCEBEB; -fx-text-fill: #A32D2D; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" text="🚨  Emergency: +20 123 456 7890" />
                                    </children>
                                </VBox>

                                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Upcoming Appointments" HBox.hgrow="ALWAYS" />
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text=" Next 30 days" />
                                            </children>
                                        </HBox>
                                        <ListView fx:id="appointmentsList" prefHeight="200" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="My Bills" HBox.hgrow="ALWAYS" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text=" Payment history" />
                                    </children>
                                </HBox>
                                <HBox spacing="10">
                                    <children>
                                        <VBox prefWidth="180" spacing="4" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 12 14;">
                                            <children>
                                                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0C447C;" text="TOTAL BILLED" />
                                                <Label fx:id="totalBillLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;" text="EGP 0" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="180" spacing="4" style="-fx-background-color: #E8F5E9; -fx-background-radius: 8; -fx-padding: 12 14;">
                                            <children>
                                                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="PAID" />
                                                <Label fx:id="paidBillLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="EGP 0" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="180" spacing="4" style="-fx-background-color: #FCEBEB; -fx-background-radius: 8; -fx-padding: 12 14;">
                                            <children>
                                                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #791F1F;" text="OUTSTANDING" />
                                                <Label fx:id="unpaidBillLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #A32D2D;" text="EGP 0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <ListView fx:id="billsList" prefHeight="150" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                            </children>
                        </VBox>

                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEEEEE; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16 20;">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Patient History Timeline" HBox.hgrow="ALWAYS" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text=" All activity" />
                                    </children>
                                </HBox>
                                <ListView fx:id="timelineList" prefHeight="180" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
