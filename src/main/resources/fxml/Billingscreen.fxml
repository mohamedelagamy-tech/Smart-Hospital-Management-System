<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.BillingController"
            prefHeight="700" prefWidth="1200"
            style="-fx-background-color: #f4f6f9;">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="12"
              style="-fx-background-color: #1E3A5F; -fx-padding: 0 24;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;
                           -fx-underline: true;"/>
            <Label text="💰  Billing Management"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f4f6f9;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-border-color: #dde1e7;
                             -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 16;">
                    <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #aaa;"/>
                    <TextField fx:id="searchField"
                               promptText="Search by patient name or bill number..."
                               prefHeight="42" HBox.hgrow="ALWAYS"
                               onKeyReleased="#applyFilters"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"/>
                </HBox>
                <ComboBox fx:id="sortBox" prefHeight="42" prefWidth="200"
                          onAction="#applyFilters"
                          style="-fx-background-color: white; -fx-border-color: #dde1e7;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <ToggleButton fx:id="btnAll" text="All"
                              style="-fx-background-color: #1F4E79; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPaid" text="Paid"
                              style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPending" text="Pending"
                              style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPartiallyPaid" text="Partially Paid"
                              style="-fx-background-color: #e67e22; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnOverdue" text="Overdue"
                              style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="newBillBtn" text="+ New Bill" onAction="#openNewBillForm"
                        style="-fx-background-color: #1F4E79; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-padding: 8 20;"/>
            </HBox>
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-color: #eeeeee; -fx-border-radius: 12; -fx-border-width: 1;">
                <TableView fx:id="billingTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colBillNum" text="Bill Number"  prefWidth="140"/>
                        <TableColumn fx:id="colPatient" text="Patient Name" prefWidth="160"/>
                        <TableColumn fx:id="colService" text="Service"      prefWidth="180"/>
                        <TableColumn fx:id="colDate"    text="Date"         prefWidth="110"/>
                        <TableColumn fx:id="colAmount"  text="Amount"       prefWidth="110"/>
                        <TableColumn fx:id="colStatus"  text="Status"       prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>