<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.BillingController"
            prefHeight="700" prefWidth="1200"
            styleClass="app-background">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="72.0" prefWidth="900.0"
              spacing="10" styleClass="top-bar">
            <Button onAction="#handleBack" styleClass="back-button" text="← Back" />
            <Label style="-fx-font-size: 24px;" styleClass="top-bar-title" text=" 💰Billing Management" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS"
                      styleClass="card" style="-fx-padding: 0 16;">
                    <Label text="🔍" styleClass="muted-text" />
                    <TextField fx:id="searchField"
                               promptText="Search by patient name or bill number..."
                               prefHeight="42" HBox.hgrow="ALWAYS"
                               onKeyReleased="#applyFilters"
                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"/>
                </HBox>
                <ComboBox fx:id="sortBox" prefHeight="42" prefWidth="200"
                          onAction="#applyFilters"
                          style="-fx-background-color: white; -fx-border-color: #dde1e7;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <ToggleButton fx:id="btnAll" text="All"
                              style="-fx-background-color: #1F4E79; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPaid" text="Paid"
                              style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPending" text="Pending"
                              style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnPartiallyPaid" text="Partially Paid"
                              style="-fx-background-color: #e67e22; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <ToggleButton fx:id="btnOverdue" text="Overdue"
                              style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-font-size: 13px; -fx-cursor: hand; -fx-pref-height: 34px;"
                              onAction="#applyFilters"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="newBillBtn" text="+ New Bill" onAction="#openNewBillForm"
                        styleClass="primary-button"/>
            </HBox>
            <VBox VBox.vgrow="ALWAYS" styleClass="card">
                <TableView fx:id="billingTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colBillNum" text="Bill Number"  prefWidth="140"/>
                        <TableColumn fx:id="colPatient" text="Patient Name" prefWidth="160"/>
                        <TableColumn fx:id="colService" text="Service"      prefWidth="180"/>
                        <TableColumn fx:id="colDate"    text="Date"         prefWidth="110"/>
                        <TableColumn fx:id="colAmount"  text="Amount"       prefWidth="110"/>
                        <TableColumn fx:id="colStatus"  text="Status"       prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>