<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.shms.controller.ChangePasswordController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="54" spacing="10"
              styleClass="top-bar" style="-fx-padding: 0 20;">
            <Button onAction="#handleBack" text="← Back"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: rgba(255,255,255,0.25); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 5 12;" />
            <Label text="🔒  Change Password"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" styleClass="app-background">
            <VBox maxWidth="440" spacing="16"
                  styleClass="card" style="-fx-padding: 36;">
                <Label text="Update Your Password"
                       styleClass="card-title" style="-fx-font-size: 18px;" />
                <Label text="Choose a strong password with at least 8 characters"
                       styleClass="muted-text" />

                <Separator />

                <VBox spacing="6">
                    <Label text="CURRENT PASSWORD" styleClass="section-label"
                           style="-fx-padding: 0;" />
                    <PasswordField fx:id="currentPasswordField"
                                   promptText="Enter current password"
                                   style="-fx-pref-height: 42px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 13px;" />
                </VBox>

                <VBox spacing="6">
                    <Label text="NEW PASSWORD" styleClass="section-label"
                           style="-fx-padding: 0;" />
                    <PasswordField fx:id="newPasswordField"
                                   promptText="Enter new password"
                                   style="-fx-pref-height: 42px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 13px;" />
                </VBox>

                <VBox spacing="6">
                    <Label text="CONFIRM NEW PASSWORD" styleClass="section-label"
                           style="-fx-padding: 0;" />
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Confirm new password"
                                   style="-fx-pref-height: 42px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-background-color: #FAFAFA; -fx-font-size: 13px;" />
                </VBox>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       style="-fx-font-size: 12px;" />

                <Button text="Update Password" maxWidth="Infinity"
                        prefHeight="44" onAction="#handleChangePassword"
                        styleClass="primary-button"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;" />

            </VBox>
        </VBox>
    </center>

</BorderPane>